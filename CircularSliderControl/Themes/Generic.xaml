<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CircularSliderControl">

    <Style TargetType="{x:Type local:CircularSlider}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CircularSlider}">
                    <Grid>
                        <Canvas x:Name="PART_Container">
                            <!-- 轨道背景 -->
                            <Path x:Name="PART_Track"
                                  Stroke="{TemplateBinding TrackBrush}"
                                  StrokeThickness="{TemplateBinding TrackThickness}"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                            
                            <!-- 进度条 -->
                            <Path x:Name="PART_Progress"
                                  Stroke="{TemplateBinding ProgressBrush}"
                                  StrokeThickness="{TemplateBinding TrackThickness}"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                            
                            <!-- 滑块 -->
                            <Ellipse x:Name="PART_Thumb"
                                     Width="{TemplateBinding ThumbSize}"
                                     Height="{TemplateBinding ThumbSize}"
                                     Fill="{TemplateBinding ThumbBrush}"
                                     Stroke="{TemplateBinding ProgressBrush}"
                                     StrokeThickness="2"
                                     Panel.ZIndex="1"
                                     Cursor="Hand">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0" Y="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" 
                                                      ShadowDepth="2" 
                                                      Opacity="0.5"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                        
                        <!-- 显示当前值 -->
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F0}°}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{TemplateBinding ProgressBrush}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>